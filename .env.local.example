# =============================================================================
# ISHYA — Variables d'environnement
# Copiez ce fichier en `.env.local` et remplissez les valeurs.
# Ne JAMAIS commiter `.env.local` (ignoré par .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
# URL publique du site (utilisée pour les emails, OAuth, sitemap, robots)
# En production : https://www.ishya.fr
# En dev local  : http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase
# https://supabase.com/dashboard → Project → Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Clé service-role (SECRÈTE — jamais exposée au client !)
# Utilisée par : webhooks Stripe, jobs, opérations admin server-side.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# -----------------------------------------------------------------------------
# Stripe
# https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
# Clé publishable (côté client — Stripe Elements)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Clé secrète (server-side uniquement — création PaymentIntent)
STRIPE_SECRET_KEY=sk_test_...

# Secret du webhook (à récupérer après création du endpoint Stripe)
# En dev : utilisez `stripe listen --forward-to localhost:3000/api/stripe/webhooks`
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# Resend (emails transactionnels)
# https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...

# Adresse expéditrice (le domaine doit être vérifié sur Resend)
# Format : "ISHYA <newsletter@ishya.fr>"
RESEND_FROM_EMAIL=ISHYA <newsletter@ishya.fr>

# -----------------------------------------------------------------------------
# Cron / sécurité
# -----------------------------------------------------------------------------
# Token partagé pour authentifier les jobs cron (panier abandonné, anniversaires).
# Vercel Cron envoie ce token dans l'en-tête Authorization: Bearer <CRON_SECRET>.
# OBLIGATOIRE en production : sans valeur, les routes /api/cron/* renvoient 503.
# En dev local : laisser vide pour pouvoir déclencher manuellement.
CRON_SECRET=

# -----------------------------------------------------------------------------
# Vercel Analytics & Speed Insights
# -----------------------------------------------------------------------------
# Aucune clé requise : les SDK @vercel/analytics et @vercel/speed-insights
# détectent automatiquement le projet quand le site est déployé sur Vercel.
# En local, les events sont envoyés en mode debug (visible dans la console).

# -----------------------------------------------------------------------------
# Sentry (monitoring d'erreurs) — optionnel
# https://sentry.io → Settings → Projects → Client Keys (DSN)
# -----------------------------------------------------------------------------
# Sentry est entièrement optionnel : si NEXT_PUBLIC_SENTRY_DSN est vide, le
# SDK n'est pas chargé et next.config.ts utilise la config sans wrapping.
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# SENTRY_DSN=                           # idem côté serveur (sinon fallback NEXT_PUBLIC_)
# SENTRY_ORG=ishya
# SENTRY_PROJECT=ishya-web
# SENTRY_AUTH_TOKEN=                    # token "Project Settings → Auth Tokens" pour l'upload des sourcemaps

# -----------------------------------------------------------------------------
# Vercel (rempli automatiquement en production)
# -----------------------------------------------------------------------------
# VERCEL_URL — fournie automatiquement par Vercel
